{
  "name": "chartjs-adapter-temporal",
  "version": "1.0.0",
  "description": "Temporal/Intl API based time adapter for Chart.js",
  "keywords": [
    "adapter",
    "chart",
    "chartjs",
    "date",
    "intl",
    "temporal",
    "time",
    "time scale"
  ],
  "license": "MIT",
  "author": "",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "dist/register.js",
    "dist/register.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "import": "./dist/register.mjs",
      "require": "./dist/register.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "runp lint:*",
    "lint:format": "oxfmt --check",
    "lint:check": "oxlint --type-aware --type-check",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsdown src/index.ts src/register.ts --clean --format esm --format cjs --sourcemap --dts --exports",
    "prepublishOnly": "runp build :p publint size-limit"
  },
  "devDependencies": {
    "@nx/js": "^22.6.3",
    "@schummar/runp": "2.2.4",
    "@size-limit/preset-small-lib": "12.0.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@vitest/coverage-v8": "4.1.2",
    "chart.js": "4.5.1",
    "nx": "^22.6.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "publint": "0.3.18",
    "size-limit": "12.0.1",
    "temporal-polyfill": "0.3.2",
    "tsdown": "^0.21.7",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "chart.js": ">=4"
  },
  "size-limit": [
    {
      "name": "index",
      "path": "dist/index.mjs",
      "limit": "1 KB"
    },
    {
      "name": "register",
      "path": "dist/register.mjs",
      "limit": "1.1 KB"
    }
  ],
  "volta": {
    "node": "24.14.1",
    "npm": "11.12.1",
    "pnpm": "10.33.0"
  }
}
